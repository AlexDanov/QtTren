    {"id":"pa01_q02","type":"single","description":[{"type":"text","text":"MainWindow отвечает за визуальное представление и пользовательские действия."}],"question":[{"type":"text","text":"Какой класс строит левую панель тестов, прогресс и карточку вопроса?"}],"options":[{"id":"a","blocks":[{"type":"text","text":"MainWindow"}]},{"id":"b","blocks":[{"type":"text","text":"QJsonDocument"}]},{"id":"c","blocks":[{"type":"text","text":"CMakeLists"}]},{"id":"d","blocks":[{"type":"text","text":"QStandardPaths"}]}],"correct":"a"},
    {"id":"pa01_q03","type":"multi","description":[{"type":"text","text":"TestManager является моделью/сервисом домена тестирования."}],"question":[{"type":"text","text":"Какие обязанности лежат на TestManager?"}],"options":[{"id":"a","blocks":[{"type":"text","text":"Загрузка тестов из JSON"}]},{"id":"b","blocks":[{"type":"text","text":"Хранение текущих ответов"}]},{"id":"c","blocks":[{"type":"text","text":"Логирование прохождения"}]},{"id":"d","blocks":[{"type":"text","text":"Отрисовка пикселей окна вручную"}]}],"correct":["a","b","c"]},
    {"id":"pa01_q04","type":"text","description":[{"type":"code","language":"cpp","text":"TestManager testManager;\ntestManager.loadTests();\nMainWindow window(&testManager);"}],"question":[{"type":"text","text":"Как называется класс модели, экземпляр которого передается в MainWindow?"}],"options":[],"correct":"TestManager"},
    {"id":"pa01_q05","type":"single","description":[{"type":"text","text":"Сборка больше не использует QML-модуль."}],"question":[{"type":"text","text":"Какой Qt-компонент теперь подключается в CMake?"}],"options":[{"id":"a","blocks":[{"type":"code","language":"cpp","text":"find_package(Qt6 REQUIRED COMPONENTS Widgets)"}]},{"id":"b","blocks":[{"type":"code","language":"cpp","text":"find_package(Qt6 REQUIRED COMPONENTS Quick)"}]},{"id":"c","blocks":[{"type":"code","language":"cpp","text":"find_package(Qt6 REQUIRED COMPONENTS Qml)"}]},{"id":"d","blocks":[{"type":"code","language":"cpp","text":"find_package(Qt6 REQUIRED COMPONENTS WebEngine)"}]}],"correct":"a"},
    {"id":"pa01_q06","type":"multi","description":[{"type":"text","text":"UI реагирует на изменения модели через сигналы Qt."}],"question":[{"type":"text","text":"Какие сигналы TestManager используются для обновления интерфейса?"}],"options":[{"id":"a","blocks":[{"type":"code","language":"cpp","text":"testsChanged"}]},{"id":"b","blocks":[{"type":"code","language":"cpp","text":"currentCardChanged"}]},{"id":"c","blocks":[{"type":"code","language":"cpp","text":"cardStatesChanged"}]},{"id":"d","blocks":[{"type":"code","language":"cpp","text":"paintPixelsChanged"}]}],"correct":["a","b","c"]},
    {"id":"pa01_q07","type":"single","description":[{"type":"text","text":"Квадраты прогресса создаются как кнопки, чтобы по ним можно было перейти к карточке."}],"question":[{"type":"text","text":"Какой метод TestManager вызывается при клике на квадрат прогресса?"}],"options":[{"id":"a","blocks":[{"type":"code","language":"cpp","text":"selectCard(index)"}]},{"id":"b","blocks":[{"type":"code","language":"cpp","text":"loadTests()"}]},{"id":"c","blocks":[{"type":"code","language":"cpp","text":"appendLogRecord(record)"}]},{"id":"d","blocks":[{"type":"code","language":"cpp","text":"highlightCode(code, lang)"}]}],"correct":"a"},
    {"id":"pa01_q08","type":"text","description":[{"type":"text","text":"Q_OBJECT нужен классам, которые используют сигналы и слоты Qt."}],"question":[{"type":"text","text":"Какой макрос Qt должен быть в QObject-классе с signals?"}],"options":[],"correct":"Q_OBJECT"},
